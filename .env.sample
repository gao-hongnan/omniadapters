# ============================================
# Environment Configuration
# ============================================
ENV=development
DEBUG=true

# ============================================
# S3 / MinIO Configuration
# ============================================
S3__ENDPOINT_URL=http://host.docker.internal:9000
S3__AWS_ACCESS_KEY_ID=minioadmin
S3__AWS_SECRET_ACCESS_KEY=minioadmin

# ============================================
# LLM Provider Configuration
# ============================================

# OpenAI
OPENAI__API_KEY=sk-...
OPENAI__MODEL_NAME=gpt-4o-mini
OPENAI__TEMPERATURE=0.0
OPENAI__MAX_COMPLETION_TOKENS=1000
OPENAI__LOGPROBS=false

# Anthropic
ANTHROPIC__API_KEY=sk-ant-...
ANTHROPIC__MODEL_NAME=claude-3-5-haiku-20241022
ANTHROPIC__TEMPERATURE=0.7
ANTHROPIC__MAX_TOKENS=1000

# Google Gemini
GEMINI__API_KEY=AIza...
GEMINI__MODEL_NAME=gemini-2.0-flash
GEMINI__TEMPERATURE=1.0
GEMINI__MAX_TOKENS=8192

# Azure OpenAI (optional)
# AZURE_OPENAI__API_KEY=...
# AZURE_OPENAI__ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI__API_VERSION=2024-02-15-preview
# AZURE_OPENAI__MODEL_NAME=gpt-4o-mini
